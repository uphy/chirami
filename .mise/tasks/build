#!/usr/bin/env bash
#MISE description="Release ビルド (.app バンドル生成)"
#MISE depends=["lint-fix"]
#MISE sources=["Chirami/**/*.swift", "Package.swift", "Chirami/Info.plist", "Chirami/Resources/Assets.xcassets/AppIcon.appiconset/AppIcon-1024.png"]
set -euo pipefail

version="${APP_VERSION:-0.0.0-dev}"

swift build -c release

# .app バンドル構成
app_dir="build/Chirami.app/Contents"
mkdir -p "$app_dir/MacOS" "$app_dir/Resources"

cp .build/release/Chirami "$app_dir/MacOS/Chirami"

# アイコン (icns) 生成
src_png="Chirami/Resources/Assets.xcassets/AppIcon.appiconset/AppIcon-1024.png"
if [ -f "$src_png" ]; then
  iconset_dir="$(mktemp -d)/AppIcon.iconset"
  mkdir -p "$iconset_dir"
  sips -z 16   16   "$src_png" --out "$iconset_dir/icon_16x16.png"    > /dev/null
  sips -z 32   32   "$src_png" --out "$iconset_dir/icon_16x16@2x.png" > /dev/null
  sips -z 32   32   "$src_png" --out "$iconset_dir/icon_32x32.png"    > /dev/null
  sips -z 64   64   "$src_png" --out "$iconset_dir/icon_32x32@2x.png" > /dev/null
  sips -z 128  128  "$src_png" --out "$iconset_dir/icon_128x128.png"   > /dev/null
  sips -z 256  256  "$src_png" --out "$iconset_dir/icon_128x128@2x.png" > /dev/null
  sips -z 256  256  "$src_png" --out "$iconset_dir/icon_256x256.png"   > /dev/null
  sips -z 512  512  "$src_png" --out "$iconset_dir/icon_256x256@2x.png" > /dev/null
  sips -z 512  512  "$src_png" --out "$iconset_dir/icon_512x512.png"   > /dev/null
  cp "$src_png"                     "$iconset_dir/icon_512x512@2x.png"
  iconutil -c icns "$iconset_dir" -o "$app_dir/Resources/AppIcon.icns"
  rm -rf "$(dirname "$iconset_dir")"
  echo "Icon: AppIcon.icns generated"
fi

# Info.plist の Xcode 変数を実値に置換
sed \
  -e 's/$(DEVELOPMENT_LANGUAGE)/en/' \
  -e 's/$(EXECUTABLE_NAME)/Chirami/' \
  -e 's/$(PRODUCT_BUNDLE_IDENTIFIER)/com.uphy.Chirami/' \
  -e "s/\$(MARKETING_VERSION)/$version/" \
  -e "s/\$(CURRENT_PROJECT_VERSION)/$version/" \
  -e 's/$(MACOSX_DEPLOYMENT_TARGET)/14.0/' \
  Chirami/Info.plist > "$app_dir/Info.plist"

echo "Built build/Chirami.app (version: $version)"
