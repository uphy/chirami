#!/usr/bin/env bash
#MISE description="~/Applications にインストール"
#MISE depends=["build"]
set -euo pipefail

app_path="build/Chirami.app"
if [ ! -d "$app_path" ]; then
  echo "Error: $app_path not found"
  exit 1
fi

# 実行中かチェック
was_running=false
is_installed=false
if [ -d ~/Applications/Chirami.app ]; then
  is_installed=true
fi
if pgrep -x Chirami >/dev/null 2>&1; then
  was_running=true
  pkill -x Chirami
  sleep 0.5
fi

mkdir -p ~/Applications
rm -rf ~/Applications/Chirami.app
cp -R "$app_path" ~/Applications/Chirami.app
echo "Installed to ~/Applications/Chirami.app"

# Create symlink so `chirami` is accessible from PATH
mkdir -p ~/.local/bin
ln -sf ~/Applications/Chirami.app/Contents/MacOS/chirami_bin ~/.local/bin/chirami
echo "Symlinked ~/.local/bin/chirami → bundle"

# 起動中だったら再起動、未インストールだったら新規起動
if [ "$was_running" = true ] || [ "$is_installed" = false ]; then
  open ~/Applications/Chirami.app
  if [ "$was_running" = true ]; then
    echo "Restarted Chirami"
  else
    echo "Started Chirami"
  fi
fi
